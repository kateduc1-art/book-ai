# Database
DATABASE_URL=postgresql+psycopg2://bookai:bookai@localhost:5432/book_ai

# OpenAI credentials and defaults
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=
EMBEDDING_MODEL=text-embedding-3-small

# Chat / LLM provider
# Supported values today: openai, openai-compatible
CHAT_PROVIDER=openai
CHAT_MODEL=

# Processing
CHUNK_SIZE=500
CHUNK_OVERLAP=50
MIN_SCORE=0.75
MAX_RESULTS=100

# Optional NotebookLM integration
USE_NOTEBOOKLM=false
NOTEBOOKLM_PROJECT_ID=
NOTEBOOKLM_LOCATION=
NOTEBOOKLM_API_KEY=
